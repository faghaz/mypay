@app.route("/post-event", methods=["GET", "POST"])
def post_event():
    if request.method == "POST":
        # --- form data ---
        title = request.form.get("title")
        location = request.form.get("location")
        date = request.form.get("date")
        description = request.form.get("description")
        price = request.form.get("price")
        zip_code = request.form.get("zip_code")
        street = request.form.get("street")
        city = request.form.get("city")
        state = request.form.get("state")
        country = request.form.get("country")

        # --- handle image upload ---
        image = request.files.get("image")
        image_path = ""
        if image and image.filename != "" and allowed_file(image.filename):
            import uuid
            filename = str(uuid.uuid4()) + "_" + secure_filename(image.filename)
            filepath = os.path.join(app.config["UPLOAD_FOLDER"], filename)
            image.save(filepath)
            image_path = f"static/uploads/{filename}"

        # --- save to database ---
        conn = sqlite3.connect("payments.db")
        c = conn.cursor()

        c.execute("""
            INSERT INTO events 
           (title, location, date, description, image_url, price, zip_code, street, city, state, country)
           VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
           """, (title, location, date, description, image_path, price, zip_code, street, city, state, country))
        conn.commit()
        conn.close()

        return redirect("/events")

    return render_template("post_event.html", countries=COUNTRIES, states=STATES)

