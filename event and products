# --- Search ---
@app.route("/search")
def search():
    query = request.args.get("q")
    conn = sqlite3.connect("payments.db")
    c = conn.cursor()
    c.execute("SELECT id, title, location FROM events WHERE title LIKE ?", (f"%{query}%",))
    results = c.fetchall()
    conn.close()

    html = "<h1>Search Results</h1>"
    for r in results:
        html += f"<p><a href='/event/{r[0]}'>{r[1]} - {r[2]}</a></p>"
    return html

# --- Payment Success ---
@app.route("/success")
def success():
    conn = sqlite3.connect("payments.db")
    c = conn.cursor()
    c.execute("UPDATE transactions SET status='success' WHERE status='pending'")
    conn.commit()
    conn.close()
    return "<h1>Payment Successful!</h1><a href='/dashboard'>Go to dashboard</a>"

# --- Dashboard ---
@app.route("/dashboard")
def dashboard():
    conn = sqlite3.connect("payments.db")
    c = conn.cursor()
    c.execute("SELECT * FROM transactions")
    transactions = c.fetchall()
    conn.close()

    html = "<h1>Payment Dashboard</h1>"
    html += "<table border=1>"
    html += "<tr><th>ID</th><th>Amount</th><th>Status</th></tr>"
    for t in transactions:
        html += f"<tr><td>{t[0]}</td><td>{t[1]}</td><td>{t[2]}</td></tr>"
    html += "</table>"
    return html

